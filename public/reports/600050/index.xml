    &lt;/div&gt;&lt;div class=&#34;decision-metric&#34;&gt;
      &lt;span class=&#34;decision-metric-label&#34;&gt;当前股价&lt;/span&gt;
      &lt;span class=&#34;decision-metric-value&#34;&gt;4.57 元&lt;/span&gt;
    &lt;/div&gt;&lt;div class=&#34;decision-metric&#34;&gt;
      &lt;span class=&#34;decision-metric-label&#34;&gt;优先级&lt;/span&gt;
      &lt;span class=&#34;decision-metric-value&#34;&gt;高优先级&lt;/span&gt;
    &lt;/div&gt;&lt;/div&gt;&lt;div class=&#34;decision-v2-body&#34;&gt;
    &lt;div class=&#34;stock-info-card&#34;&gt;
&lt;div class=&#34;stock-info-header&#34;&gt;
