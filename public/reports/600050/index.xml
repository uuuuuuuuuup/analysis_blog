  &lt;span class=&#34;info-label&#34;&gt;持股渠道&lt;/span&gt;
  &lt;span class=&#34;info-value&#34;&gt;A股直接持有&lt;/span&gt;
&lt;/div&gt;
&lt;div class=&#34;info-row&#34;&gt;
  &lt;span class=&#34;info-label&#34;&gt;总股本&lt;/span&gt;
